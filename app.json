{
  "expo": {
    "name": "chat-app",
    "slug": "chat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chatapp",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohamed.chatapp",
      "icon": {
        "dark": "./assets/ios/ios-dark.png",
        "light": "./assets/ios/ios-light.png",
        "tinted": "./assets/ios/ios-tinted.png"
      }
    },
    "android": {
      "package": "com.mohamed.chatapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android/adaptive-icon.png",
        "monochromeImage": "./assets/android/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F",
          "dark": {
            "image": "./assets/icons/splash-icon-dark.png",
            "backgroundColor": "#0A0A0F"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc10ff07-cfb4-407d-8051-e7bbf5957664"
      }
    },
    "owner": "elmostapha"
  }
}
